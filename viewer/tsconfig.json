{
  "compileOnSave": false,
  "compilerOptions": {
    "declaration": false,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "lib": [
      "ES2018",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "noFallthroughCasesInSwitch": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "target": "ES2019",
    "resolveJsonModule": true,
    "rootDir": "${configDir}",
    "strict": true,
    "paths": {
      "@reveal/*": [
        "./packages/*"
      ],
      "*": [
        "./*"
      ]
    },
  },
  "include": [],
  "exclude": [],
  "files": [],
  "references": [
    {
      "path": "tsconfig.webpack.json"
    }
  ]
}
