{
  "compileOnSave": false,
  "compilerOptions": {
    "declaration": false,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "lib": [
      "ES2019",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "noFallthroughCasesInSwitch": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "target": "ES2019",
    "resolveJsonModule": true,
    "rootDir": ".",
    "strict": true,
    "paths": {
      "@reveal/*": [
        "./packages/*"
      ],
      "*": [
        "./*"
      ]
    },
  }
}
