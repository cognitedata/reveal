  ],
  "workspaces": [
    "versioned_docs/*",
    "docs"
  ],
  "scripts": {
    "start": "cross-env HTTPS=true NODE_OPTIONS=--max_old_space_size=8192 docusaurus start --port=9000",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=8192 docusaurus build",
    "build:fast": "cross-env NODE_OPTIONS=--max_old_space_size=8192 docusaurus build --no-minify",
    "swizzle": "docusaurus swizzle",
    "ws:removeFiles": "rimraf",
    "ws:copyfiles": "copyfiles",
    "ws:replace": "replace"
  },
  "dependencies": {
    "@azure/msal-browser": "4.30.0",
    "@codemirror/lang-javascript": "6.2.5",
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@docusaurus/remark-plugin-npm2yarn": "3.10.1",
    "@uiw/codemirror-theme-material": "4.25.10",
    "@uiw/react-codemirror": "4.25.10",
    "clsx": "2.1.1",
    "cross-env": "10.1.0",
    "ieee754": "1.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "styled-components": "6.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "copyfiles": "2.4.1",
    "docusaurus-plugin-typedoc": "1.4.2",
    "replace": "1.2.2",
    "rimraf": "6.1.3",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typedoc-plugin-no-inherit": "1.6.1",
    "typescript": "6.0.3"
  },
  "browserslist": {
    "production": [
      ">1%",
      "not dead",
      "not ie 11",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "webpack": "5.108.1",
    "serialize-javascript": "^7.0.3",
    "replace/minimatch": "^10.0.0",
    "@chevrotain/cst-dts-gen/lodash": "^4.18.1",
    "@chevrotain/gast/lodash": "^4.18.1",
