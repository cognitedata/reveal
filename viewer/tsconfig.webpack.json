{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "${configDir}",
    "outDir": "${configDir}/dist",
    "declaration": true,
    "types": ["vite/client", "node", "./custom.d.ts", "./packages/api/src/@types/modules/index.d.ts"]
  },
  "include": ["${configDir}/packages/**/*.ts", "${configDir}/api-entry-points/**/*.ts"],
  "exclude": [
    "./packages/**/*.d.ts",
    "./packages/**/*.spec.ts",
    "./packages/**/*.test.ts",
    "./packages/**/*.interaction.ts",
    "./packages/**/__fixtures__/**/*.ts",
    "./packages/**/__mocks__/**/*.ts",
    "./packages/**/__tests__/**/*.ts",
    "**/visual-tests/**/*.ts",
    "**/node_modules/**",

  ],
  "files": ["./index.ts"],
}
