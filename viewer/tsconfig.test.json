{
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "vitest/globals",
      "vite/client",
      "vite-plugin-glsl/ext",
      "vitest",
      "node",
    ]
  },
  "include": [
    "./src/**/*.spec.ts",
    "./src/**/*.test.ts",
    "./src/**/__fixtures__/**/*.ts",
    "./src/**/__mocks__/**/*.ts",
    "./src/**/__tests__/**/*.ts",
    "./test-utilities/**/*.ts"
  ],
  "exclude": ["**/node_modules/**", "**VisualTest.ts",],
  "files": ["vite.config.ts"],
  "extends": ["./tsconfig.json"]
}
