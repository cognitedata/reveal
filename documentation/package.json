{
  "name": "@cognite/reveal-documentation",
  "version": "1.0.0",
  "private": true,
  "author": "Lars Moastuen <lars.moastuen@cognite.com>",
  "contributors": [
    "Christopher Tannum <christopher.tannum@cognite.com>",
