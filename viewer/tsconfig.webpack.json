{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "${configDir}",
    "outDir": "${configDir}/dist",
    "declaration": true,
    "isolatedDeclarations": true,
    "types": ["vite/client", "node"]
  },
  "include": ["${configDir}/packages/**/*.ts", "${configDir}/packages/**/*.tsx"],
  "exclude": [
    "${configDir}/packages/**/*.d.ts",
    "${configDir}/packages/**/*.stories.ts",
    "${configDir}/packages/**/*.stories.tsx",
    "${configDir}/packages/**/*.spec.ts",
    "${configDir}/packages/**/*.spec.tsx",
    "${configDir}/packages/**/*.test.ts",
    "${configDir}/packages/**/*.test.tsx",
    "${configDir}/packages/**/*.interaction.ts",
    "${configDir}/packages/**/*.interaction.tsx",
    "${configDir}/packages/**/__fixtures__/**/*.ts",
    "${configDir}/packages/**/__fixtures__/**/*.tsx",
    "${configDir}/packages/**/__mocks__/**/*.ts",
    "${configDir}/packages/**/__mocks__/**/*.tsx",
    "${configDir}/packages/**/__tests__/**/*.ts",
    "${configDir}/packages/**/__tests__/**/*.tsx",
    "${configDir}/packages/**/__stories__/**/*.ts",
    "${configDir}/packages/**/__stories__/**/*.tsx",
    "**/node_modules",
    "**/dist"
  ],
  "files": ["./index.ts"],
}
