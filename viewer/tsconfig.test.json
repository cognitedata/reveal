{
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "vitest/globals",
      "vite/client",
      "vite-plugin-glsl/ext",
      "vitest",
      "node",
    ]
  },
  "include": [
    "./packages/**/*.spec.ts",
    "./packages/**/*.test.ts",
    "./packages/**/__fixtures__/**/*.ts",
    "./packages/**/__mocks__/**/*.ts",
    "./packages/**/__tests__/**/*.ts",
    "./visual-tests/**/*.ts",
    "./test-utilities/**/*.ts"
  ],
  "exclude": ["**/node_modules/**", "**VisualTest.ts"],
  "files": ["vite.config.ts"],
  "extends": ["./tsconfig.json"]
}
