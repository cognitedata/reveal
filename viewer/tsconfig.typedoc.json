{
  "compilerOptions": {
    "target": "ES2019",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "dom",
      "webworker"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "allowJs": true,
  },
  "exclude": [
    "./**/*.test.ts",
    "./test-utilities/**",
    "./visual-tests/**",
    "./**/visual-tests/**",
  ]
}
